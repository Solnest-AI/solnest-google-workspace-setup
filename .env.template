# ============================================================
#  solnest-google-workspace-setup — YOUR KEYS
#
#  Paste your keys after the = signs. No quotes. No spaces.
#      GOOD:  EXA_API_KEY=abc123
#      BAD:   EXA_API_KEY = "abc123"
#
#  Save this file, then tell Claude you're done.
#  NEVER paste a key into the chat window. NEVER commit this file.
# ============================================================

# Google OAuth Client ID (not secret, but keep it together)
# Get it: https://console.cloud.google.com/auth/clients
GOOGLE_OAUTH_CLIENT_ID=

# Google OAuth Client SECRET — treat like a password
# Get it: https://console.cloud.google.com/auth/clients
GOOGLE_OAUTH_CLIENT_SECRET=

# The Google account you're connecting (your email)
# Get it: your own email address
USER_GOOGLE_EMAIL=
